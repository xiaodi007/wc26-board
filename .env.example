# The Odds API — 免费注册 https://the-odds-api.com/ (500 credits/月)
# 没有 key 时采集器跑纯 Polymarket 模式
ODDS_API_KEY=

# 可选: 代理(大陆直连 PM 偶发抖动,翻墙代理更稳)
# HTTPS_PROXY=http://127.0.0.1:7890

# 轮询间隔覆盖(毫秒)。免费 Odds API 层默认 90min,升级 $30/20K 后可改 15min
# PM_POLL_MS=300000
# KALSHI_POLL_MS=300000
# ODDSAPI_POLL_MS=5400000

# Polymarket market intelligence enrichment.
# Gamma provides liquidity/volume/spread; Data API holders/trades provide participation signals.
# Increase cautiously: /trades can be large. Capped batches are marked sampled in the UI.
# PM_DATA_BASE=https://data-api.polymarket.com
# PM_PARTICIPATION_MAX_MARKETS=90
# PM_PARTICIPATION_BATCH_SIZE=10
# PM_PARTICIPATION_TRADE_LIMIT=10000
# PM_PARTICIPATION_HOLDER_LIMIT=20
# PM_PARTICIPATION_LOOKBACK_HOURS=24

# AI 分析(board 详情页)。不配 key 时面板降级为 prompt 预览+复制。
# AI_PROVIDER=anthropic|deepseek|kimi|openai-compatible；默认 anthropic,兼容旧配置。
# AI_PROVIDER=anthropic
# AI_MAX_TOKENS=4000
# AI_THINKING=off
# AI_TEMPERATURE=
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-6

# DeepSeek OpenAI-compatible 口。默认 base/model 跟本机 deepseek-kimi-workflow skill 对齐。
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
# DEEPSEEK_THINKING_MODEL=deepseek-v4-pro
# DEEPSEEK_THINKING=off
# DEEPSEEK_REASONING_EFFORT=high

# Kimi/Moonshot OpenAI-compatible 口。KIMI_API_KEY 与 MOONSHOT_API_KEY 二选一。
# AI_PROVIDER=kimi
# KIMI_API_KEY=
# MOONSHOT_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_CHAT_MODEL=kimi-k2.6
# KIMI_DEFAULT_TEMPERATURE=1

# 其它 OpenAI-compatible 服务商。
# AI_PROVIDER=openai-compatible
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_BASE_URL=
# OPENAI_COMPAT_MODEL=

# BOARD_PORT=4626

# Walrus public data feed.
# V1 exports sanitized aggregate snapshots only: no API keys, no private keys, no raw wallet addresses, no full SQLite DB.
# Use npm run export:walrus for local JSON artifacts. Publishing requires an authenticated/available publisher.
# WALRUS_ENABLED=false
# WALRUS_NETWORK=testnet
# WALRUS_EPOCHS=3
# WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# WALRUS_FEED_DIR=./data/walrus-feed

# 告警: Server酱微信推送(sct.ftqq.com 注册拿 SendKey)。不配则只落库、board 页可见
# 免费版每日配额小,事件合并成一条推 + 日上限兜底
# SERVERCHAN_KEY=
# ALERT_JUMP_PP=3
# ALERT_MAX_PER_DAY=5
