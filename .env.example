# The Odds API — 免费注册 https://the-odds-api.com/ (500 credits/月)
# 没有 key 时采集器跑纯 Polymarket 模式
ODDS_API_KEY=

# 可选: 代理(大陆直连 PM 偶发抖动,翻墙代理更稳)
# HTTPS_PROXY=http://127.0.0.1:7890

# 轮询间隔覆盖(毫秒)。免费 Odds API 层默认 90min,升级 $30/20K 后可改 15min
# PM_POLL_MS=300000
# KALSHI_POLL_MS=300000
# ODDSAPI_POLL_MS=5400000

# AI 分析(board 详情页)。不配 key 时面板降级为 prompt 预览+复制
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# BOARD_PORT=4626

# 告警: Server酱微信推送(sct.ftqq.com 注册拿 SendKey)。不配则只落库、board 页可见
# 免费版每日配额小,事件合并成一条推 + 日上限兜底
# SERVERCHAN_KEY=
# ALERT_JUMP_PP=3
# ALERT_MAX_PER_DAY=5
